generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String   @id @default(uuid())
  name               String
  plan               String   @default("starter")
  stripeCustomerId   String?
  stripeSubscriptionId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  users              User[]
  scans              Scan[]
  auditLogs          AuditLog[]
  scheduledScans     ScheduledScan[]
  webhooks           Webhook[]
  apiKeys            ApiKey[]
  invites            Invite[]
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  verified          Boolean  @default(false)
  role              String   @default("user")
  orgId             String
  org               Organization @relation(fields: [orgId], references: [id])
  createdScans      Scan[]   @relation("CreatedBy")
  notifications     Notification[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Scan {
  id            String   @id @default(uuid())
  target        String
  scanType      String   @default("full")
  status        String   @default("pending")
  resultJson    Json?
  statistics    Json?
  executiveSummary Json?
  durationSeconds Float?
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id])
  createdById   String
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])
  assets        Asset[]
  cloudAssets   CloudAsset[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Asset {
  id            String   @id @default(cuid())
  domain        String
  subdomain     String
  ip            String?
  port          Int
  service       String   @default("")
  banner        String   @default("")
  technology    String?
  version       String?
  cves          String[] @default([])
  riskScore     Int      @default(0)
  findings      Json?    @default("[]")
  headers       Json?    @default("{}")
  sslInfo       Json?
  waf           String?
  scanId        String
  scan          Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model CloudAsset {
  id              String   @id @default(cuid())
  provider        String
  serviceType     String
  resourceId      String
  url             String
  permissions     String[] @default([])
  misconfigurations Json?  @default("[]")
  riskScore       Int      @default(0)
  severity        String   @default("medium")
  scanId          String
  scan            Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  actorEmail  String?
  ip          String?
  metadata    Json?
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  createdAt   DateTime @default(now())
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  plan      String
  message   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
}

// ─── Professional EASM Models ──────────────────────────────────────────────

model ScheduledScan {
  id        String   @id @default(uuid())
  name      String
  target    String
  scanType  String   @default("full")
  cron      String   // e.g. "0 0 * * 1" for weekly Monday
  enabled   Boolean  @default(true)
  nextRun   DateTime
  lastRun   DateTime?
  lastScanId String?
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  secret    String?  // HMAC signature
  events    String[] @default(["scan.completed","scan.failed"])
  active    Boolean  @default(true)
  lastStatus Int?    // last HTTP status
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(uuid())
  name      String
  keyHash   String   @unique
  permissions String[] @default(["scan:read","scan:create"])
  lastUsed  DateTime?
  expiresAt DateTime?
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Invite {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  role      String   @default("user")
  accepted  Boolean  @default(false)
  expiresAt DateTime
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // scan_complete, scan_failed, alert, invite
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json?    // related scanId, etc.
  createdAt DateTime @default(now())
}
