# === REQUIRED ===
# PostgreSQL connection (use connection_limit for Prisma pooling)
DATABASE_URL=postgresql://shadowuser:shadowpass@postgres:5432/shadowdb?schema=public&connection_limit=10&pool_timeout=10

# Redis connection
REDIS_URL=redis://redis:6379

# JWT secret - MUST be at least 32 characters! Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-32-char-random-string-minimum-required

# Public URL of your app (used in emails, Stripe redirects, sitemap)
APP_URL=https://shadowsurface.com

# === OPTIONAL (for payments) ===
# Stripe keys - get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs - create products in Stripe Dashboard
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# === OPTIONAL (for emails) ===
# Resend API key - get from https://resend.com
# If not set, verification emails are logged to console
RESEND_API_KEY=re_...
