[Unit]
Description=ShadowSurface Next.js App
After=network.target

[Service]
Type=simple
User=shadowsurface
WorkingDirectory=/opt/shadowsurface/nextjs
ExecStart=/usr/bin/npm run start
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=3000
StandardOutput=journal
StandardError=journal
SyslogIdentifier=shadowsurface-app

[Install]
WantedBy=multi-user.target
